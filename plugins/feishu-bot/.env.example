# 飞书机器人配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 默认聊天ID（可选）
FEISHU_DEFAULT_CHAT_ID=your_default_chat_id

# OpenCode API 配置
OPENCODE_API_URL=http://localhost:4096

# 消息处理配置
FEISHU_MESSAGE_ID_TTL=3600000
FEISHU_MESSAGE_EXPIRY_TIME=120000
FEISHU_PROCESSING_TIMEOUT=5000

# 日志配置
FEISHU_LOG_LEVEL=info
FEISHU_DEBUG=false
