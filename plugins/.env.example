# 飞书应用配置（必填）
# 从飞书开放平台获取：https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 默认通知群 ID（可选）
# 用于自动通知功能，在飞书群设置中获取
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxx

# 自动通知开关（可选）
# 会话完成时发送通知
FEISHU_NOTIFY_ON_COMPLETE=false
# 会话出错时发送通知
FEISHU_NOTIFY_ON_ERROR=false

# 飞书域名（可选）
# 国内版默认为 Lark，海外版使用 Feishu
# FEISHU_DOMAIN=Lark